<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.AITaste.mapper.VoucherOrderMapper">

    <resultMap id="UserVoucherVOMap" type="com.AITaste.VO.UserVoucherVO">
        <id column="id" property="id"/>
        <result column="voucher_id" property="voucherId"/>
        <result column="title" property="title"/>
        <result column="shop_name" property="shopName"/>
        <result column="rules" property="rules"/>
        <result column="amount" property="amount"/>
        <!-- 注意：status 字段在 SQL 中已经动态计算为 0/1/2，直接映射 -->
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="use_time" property="useTime"/>
        <result column="expire_time" property="expireTime"/>
    </resultMap>

    <!-- 查询用户优惠券，自动计算实际状态（根据过期时间） -->
    <select id="selectUserVouchers" resultMap="UserVoucherVOMap">
        SELECT
        o.id,
        o.voucher_id,
        o.qr_code,
        o.status,
        o.create_time,
        o.use_time,
        o.expire_time,
        v.title,
        v.rules,
        v.pay_value,
        s.name as shop_name
        FROM tb_voucher_order o
        LEFT JOIN tb_voucher v ON o.voucher_id = v.id
        LEFT JOIN tb_shop s ON v.shop_id = s.id
        WHERE o.user_id = #{userId}
        <if test="status != null">
            AND o.status = #{status}
        </if>
        ORDER BY o.create_time DESC
    </select>
</mapper>